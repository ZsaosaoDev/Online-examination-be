# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/meet_db
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# Frontend Callback URL (for OAuth2)
FRONTEND_CALLBACK_URL=http://localhost:3000/auth/google-callback

# Application
APP_NAME=springboot-meet
SERVER_PORT=8080

# Refresh Token Configuration
REFRESH_TOKEN_MAX_AGE=604800

# JWT Configuration
ACCESS_TOKEN_EXPIRATION=900000
JWT_SECRET=your_jwt_secret_key_here
